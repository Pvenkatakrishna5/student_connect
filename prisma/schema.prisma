generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  student
  employer
  admin
}

enum JobStatus {
  active
  pending
  paused
  closed
}

enum ApplicationStatus {
  applied
  shortlisted
  selected
  rejected
  completed
}

enum NotificationType {
  info
  success
  warning
  error
}

enum ComplaintStatus {
  open
  under_review
  resolved
  dismissed
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student           Student?
  employer          Employer?
  sentMessages      Message[]      @relation("SentMessages")
  receivedMessages  Message[]      @relation("ReceivedMessages")
  notifications     Notification[]
  activities        Activity[]
  ratingsGiven      Rating[]       @relation("RatingsGiven")
  ratingsReceived   Rating[]       @relation("RatingsReceived")
  complaintsFrom    Complaint[]    @relation("ComplaintsFrom")
  complaintsAgainst Complaint[]    @relation("ComplaintsAgainst")
}

model Student {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  college           String   @default("")
  branch            String   @default("")
  year              String   @default("")
  city              String   @default("")
  phone             String   @default("")
  skills            String[]
  availability      Json     @default("{}")
  bio               String   @default("")
  profileImage      String   @default("")
  resumeUrl         String   @default("")
  experience        Json     @default("[]")
  education         Json     @default("[]")
  rating            Float    @default(0)
  totalRatings      Int      @default(0)
  totalEarnings     Float    @default(0)
  completedJobs     Int      @default(0)
  savedJobs         String[]
  aadhaarNumber     String   @default("")
  isAadhaarVerified Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  applications Application[]
}

model Employer {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName        String
  contactName        String
  phone              String   @default("")
  city               String   @default("")
  description        String   @default("")
  logo               String   @default("")
  website            String   @default("")
  isVerifiedBusiness Boolean  @default(false)
  rating             Float    @default(0)
  totalRatings       Int      @default(0)
  totalJobsPosted    Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  jobs         Job[]
  applications Application[]
}

model Job {
  id              String    @id @default(cuid())
  title           String
  description     String
  category        String
  payType         String    // hourly | fixed | monthly | per-word | per-day
  payAmount       Float
  duration        String    @default("")
  location        String    @default("Remote")
  isRemote        Boolean   @default(false)
  skillsRequired  String[]
  status          JobStatus @default(pending)
  employerId      String
  employer        Employer  @relation(fields: [employerId], references: [id], onDelete: Cascade)
  applicantsCount Int       @default(0)
  hiredCount          Int       @default(0)
  spotsAvailable      Int       @default(1)
  verificationRequired Boolean   @default(false)
  deadline            DateTime?
  startDate           String    @default("Immediate")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  applications Application[]
  ratings      Rating[]
  complaints   Complaint[]
}

model Application {
  id         String            @id @default(cuid())
  jobId      String
  job        Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  employerId String
  employer   Employer          @relation(fields: [employerId], references: [id], onDelete: Cascade)
  status     ApplicationStatus @default(applied)
  coverNote  String            @default("")
  appliedAt  DateTime          @default(now())
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([jobId, studentId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  recipient   User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        NotificationType @default(info)
  read        Boolean          @default(false)
  link        String?
  createdAt   DateTime         @default(now())
}

model Rating {
  id        String   @id @default(cuid())
  fromId    String
  from      User     @relation("RatingsGiven", fields: [fromId], references: [id], onDelete: Cascade)
  toId      String
  to        User     @relation("RatingsReceived", fields: [toId], references: [id], onDelete: Cascade)
  toRole    String
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  score     Int
  review    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Complaint {
  id          String          @id @default(cuid())
  fromId      String
  from        User            @relation("ComplaintsFrom", fields: [fromId], references: [id], onDelete: Cascade)
  againstId   String
  against     User            @relation("ComplaintsAgainst", fields: [againstId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  reason      String
  description String
  status      ComplaintStatus @default(open)
  adminNote   String          @default("")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String   // user_registered | job_posted | application_submitted | etc.
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Otp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
